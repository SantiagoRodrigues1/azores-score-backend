# Backend Configuration (.env)
# Copy this file to .env and fill in the values.
# On Render: set every variable via Environment > Environment Variables (never commit .env).

# ── Database ─────────────────────────────────────────────────────────────────
# Required. Use a MongoDB Atlas connection string in production.
MONGO_URI=mongodb+srv://dbUser:<password>@cluster0.jvkj2we.mongodb.net/AzoresScorepap?retryWrites=true&w=majority

# ── Migração automática Local → Atlas ────────────────────────────────────────
# Opcional. Se ambas estiverem definidas, o servidor copiará automaticamente
# todos os dados locais para o Atlas na primeira execução em produção.
# Deixar em branco se não quiser migração automática.
#
# URI da base de dados local (origem da migração)
# ⚠  Atenção: o nome da BD deve coincidir com o usado localmente.
MONGO_LOCAL_URI=mongodb://localhost:27017/AzoresScorepap
#
# URI do MongoDB Atlas (destino da migração e dos scripts de backup)
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_ATLAS_URI=mongodb+srv://dbUser:<password>@cluster0.jvkj2we.mongodb.net/AzoresScorepap?retryWrites=true&w=majority

# ── Backup / Restore (scripts/exportBackup.js + scripts/importBackup.js) ─────
# Usar os mesmos valores de MONGO_LOCAL_URI e MONGO_ATLAS_URI acima.
# Não são necessárias variáveis adicionais para os scripts de backup.
#
# Comandos:
#   npm run db:export   → exporta BD local  → backup/backup-YYYY-MM-DD_HH-MM-SS.json
#   npm run db:import   → importa o backup  → MongoDB Atlas (Render)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
# Render injects PORT automatically – leave blank or remove in production.
PORT=3000
NODE_ENV=development
# Public URL of this backend service (used in billing redirect URLs, etc.)
# Production example: https://azores-score-backend.onrender.com
PUBLIC_API_URL=http://localhost:3000
LOG_LEVEL=info
DEBUG_LOGS=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use '*' only for local testing. In production set your Render static-site URL.
# e.g. CORS_ORIGIN=https://your-frontend.onrender.com
CORS_ORIGIN=*
# Set to 'true' only if the frontend sends credentials (cookies / Authorization header with credentials mode)
CORS_CREDENTIALS=false

# ── Frontend URL (used by Stripe redirects + email verification links) ───────
# Must match your deployed static-site URL on Render (no trailing slash).
# Production example: https://azores-score-frontend.onrender.com
FRONTEND_URL=http://localhost:8000
# APP_URL: base URL sent in verification emails (defaults to FRONTEND_URL if not set).
# Usually the same as FRONTEND_URL. Override only if you have a custom domain.
APP_URL=http://localhost:8000

# ── Stripe Billing (optional – remove if billing is not used) ────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudinary (optional – leave all three empty to use local disk uploads) ──
# If any one is set, all three must be set.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email / Verificação de conta ─────────────────────────────────────────────
# Remetente dos emails automáticos (conta Gmail).
EMAIL_USER=santiagoescolaprofissional@gmail.com
#
# IMPORTANTE: não usar a password normal do Gmail.
# Criar uma "App Password" (Palavra-passe de aplicação):
#   1. Activar verificação em dois passos na conta Google
#   2. Conta Google → Segurança → Palavras-passe de aplicações
#   3. Gerar para "Mail" e copiar aqui (16 caracteres, sem espaços)
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
#
# Tempo de expiração (em horas) do token de verificação de email.
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
